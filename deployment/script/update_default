#!/bin/bash
set -e
set -o pipefail

VPS_USER=youruser
VPS_HOST=your.vps.ip.or.domain
GITHUB_REPO=yourusername/toro
REMOTE_DIR=/opt/toro
REMOTE_BIN="$REMOTE_DIR/server/target/release/server"

echo "Starting deployment to $VPS_HOST"

echo "Pulling latest files on server"
ssh "$VPS_USER@$VPS_HOST" "cd '$REMOTE_DIR'; git pull" || {
    echo "Failed to pull repo"
    exit 1
}

echo "Stopping toro service"
ssh "$VPS_USER@$VPS_HOST" "sudo supervisorctl stop toro" || {
    echo "Failed to stop toro with supervisor"
    exit 1
}

echo "Downloading latest release binary"
DOWNLOAD_URL="https://github.com/$GITHUB_REPO/releases/latest/download/server"
ssh "$VPS_USER@$VPS_HOST" "curl -fL '$DOWNLOAD_URL' -o '$REMOTE_BIN' && chmod +x '$REMOTE_BIN'" || {
    echo "Failed to download binary"
    exit 1
}

echo "Restarting toro service"
ssh "$VPS_USER@$VPS_HOST" "sudo supervisorctl start toro" || {
    echo "Failed to start toro with supervisor"
    exit 1
}

echo "Checking service status"
ssh "$VPS_USER@$VPS_HOST" "sudo supervisorctl status toro"

echo "Deployment complete"
